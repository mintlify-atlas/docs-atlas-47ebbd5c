  "keyFeatures": [
    "Monolithic BSD kernel with loadable module support",
    "Multi-architecture support: amd64, arm, arm64, i386, powerpc, riscv",
    "Full POSIX-compliant userland with hundreds of system utilities",
    "Advanced networking stack with IPv4, IPv6, IPsec, and 802.11 wireless",
    "OpenZFS and UFS/FFS filesystem support",
    "DTrace dynamic tracing framework",
    "Capsicum capability-based security framework",
    "mport package manager integration",
    "Linux binary compatibility layer",
    "Comprehensive system library collection (libc, libcam, libgeom, etc.)"
  ],
  "publicApiSurface": [
    "buildworld — rebuild entire userland from source",
    "buildkernel — compile the MidnightBSD kernel and modules",
    "installworld — install the built userland to disk",
    "installkernel — install the compiled kernel",
    "sysctl(8) — read/write kernel state at runtime",
    "kldload(8) / kldunload(8) — dynamic kernel module loading",
    "ifconfig(8) — network interface configuration",
    "pfctl(8) — packet filter control",
    "ipfw(8) — IP firewall administration",
    "camcontrol(8) — CAM SCSI device control",
    "geom(8) — GEOM disk framework control",
    "dtrace(1) — dynamic tracing",
    "make(1) — build system entry point",
    "libmport — package manager library API"
  ]
